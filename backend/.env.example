# Server Port Configuration
PORT=5000

# MongoDB Connection String (Atlas URI or local MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/preppilot?retryWrites=true&w=majority

# Secret key used for signing JSON Web Tokens (JWT)
JWT_SECRET=your_jwt_super_secret_key_change_me_in_production

# Optional: OpenAI API Key for AI Interview Prep generation.
# If left blank, PrepPilot will automatically fall back to generating realistic mock questions.
OPENAI_API_KEY=
